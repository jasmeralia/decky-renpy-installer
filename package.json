{
  "name": "renpy-installer",
  "version": "0.0.31",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:zip": "pnpm run build && rm -rf /tmp/decky-pkg && mkdir -p /tmp/decky-pkg/decky-renpy-installer/dist && cp plugin.json main.py package.json /tmp/decky-pkg/decky-renpy-installer/ && cp dist/index.js /tmp/decky-pkg/decky-renpy-installer/dist/ && cd /tmp/decky-pkg && VERSION=$(node -p \"require('$OLDPWD/package.json').version\") && zip -r \"$OLDPWD/decky-renpy-installer-$VERSION.zip\" decky-renpy-installer/",
    "watch": "rollup -c -w",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "@decky/ui": "^4.9.1",
    "decky-frontend-lib": "^3.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "pnpm": {
    "overrides": {
      "rollup@>=4.0.0 <4.59.0": "4.59.0"
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "react-icons": "^5.6.0",
    "rollup": "^4.59.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-external-globals": "^0.13.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  }
}
