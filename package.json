{
  "name": "renpy-installer",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:zip": "pnpm run build && zip -r decky-renpy-installer.zip plugin.json main.py dist/index.js package.json",
    "watch": "rollup -c -w",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "@decky/ui": "^4.9.1",
    "decky-frontend-lib": "^3.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "rollup": "^4.21.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "typescript": "^5.5.4"
  }
}
